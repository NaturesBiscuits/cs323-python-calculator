import random
import time

def insertion_sort(arr):
    for i in range(1, len(arr)):
        key = arr[i]
        j = i - 1

        while j >= 0 and arr[j] > key:
            arr[j + 1] = arr[j]
            j -= 1

        arr[j + 1] = key

    return arr

data = [random.randint(1, 1000) for _ in range(1000)]

start = time.time()
insertion_sort(data)
end = time.time()

print("Time:", end - start)
